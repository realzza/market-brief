# Copy to .env and fill in your values. Do NOT commit .env.

# REQUIRED — your Anthropic API key for tweet analysis
ANTHROPIC_API_KEY=sk-ant-...

# Optional — comma-separated X handles to track. Overrides the built-in
# default roster (aleabitoreddit, realDonaldTrump). Handles not in the curated
# registry render with their @handle as the display name.
# TRACKED_HANDLES=aleabitoreddit,realDonaldTrump

# Optional — legacy single-account var. Still used as the attribution for
# tweet rows that predate multi-analyst support (default: aleabitoreddit).
TWITTER_USERNAME=aleabitoreddit

# Optional — IANA timezone for container logs (default: UTC)
TZ=America/New_York

# Optional — host port to expose the app on (default: 3737)
# Change this if 3737 is taken on your machine. The container always
# listens on 3000 internally; this only affects the host-side binding.
PORT_HOST=3737

# ─────────────────────────────────────────────────────────────────────────
# Fresh-tweet path via RSSHub (opt-in)
# ─────────────────────────────────────────────────────────────────────────
# The free Twitter syndication endpoint is increasingly cached for many
# individual accounts (months stale). RSSHub can scrape live data but the
# current /twitter/user/:id route needs all THREE values below.
#
# Without these, RSSHub returns 503 and the app silently falls back to
# syndication — so populating these is opt-in.

# 1) AUTH TOKEN — the `auth_token` cookie from a logged-in browser session.
#    How to get: log into x.com in any browser → open DevTools (F12) →
#    Application → Cookies → x.com → copy the value of the `auth_token`
#    cookie. It looks like a 40-char hex string.
#    SECURITY: this cookie is equivalent to a login session — only use a
#    sacrificial / throwaway account, never your real one.
TWITTER_AUTH_TOKEN=

# 2 & 3) CONSUMER KEY + SECRET — from a Twitter Developer App.
#    How to get:
#      a. Go to https://developer.x.com and apply for an account (free tier).
#      b. After approval, create a new Project + App.
#      c. In the App's "Keys and tokens" tab, copy the "API Key" (consumer
#         key) and "API Key Secret" (consumer secret).
#    The Free dev tier is usually enough for read-only timeline access.
TWITTER_CONSUMER_KEY=
TWITTER_CONSUMER_SECRET=

# To disable the RSSHub path entirely (always use syndication):
# RSSHUB_URL=
