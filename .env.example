# Copy to .env and fill in your values. Do NOT commit .env.

# REQUIRED — your Anthropic API key for tweet analysis
ANTHROPIC_API_KEY=sk-ant-...

# Optional — X account to track (default: aleabitoreddit)
TWITTER_USERNAME=aleabitoreddit

# Optional — IANA timezone for container logs (default: UTC)
TZ=America/New_York

# Optional — host port to expose the app on (default: 3737)
# Change this if 3737 is taken on your machine. The container always
# listens on 3000 internally; this only affects the host-side binding.
PORT_HOST=3737

# ─────────────────────────────────────────────────────────────────────────
# Fresh-tweet path via RSSHub (opt-in)
# ─────────────────────────────────────────────────────────────────────────
# The free Twitter syndication endpoint is increasingly cached/segmented —
# many individual accounts return data months stale. Self-hosted RSSHub
# can scrape live data, but Twitter requires a real account login to
# return tweets via its scraper routes.
#
# To enable: create or repurpose a Twitter account you don't mind being
# rate-limited or banned (a "sacrificial" account), then fill these in:

TWITTER_LOGIN_USERNAME=
TWITTER_LOGIN_PASSWORD=
# Optional — only needed if Twitter prompts for phone/email confirmation:
TWITTER_LOGIN_PHONE_OR_EMAIL=
# Optional — TOTP base32 secret if the account has 2FA enabled:
TWITTER_LOGIN_2FA_SECRET=

# If you'd rather disable the RSSHub path entirely (always use syndication):
# RSSHUB_URL=
